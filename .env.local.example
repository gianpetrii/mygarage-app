# Copia este archivo a .env.local y completá los valores
# cp .env.local.example .env.local

# ─── Firebase — Project Settings → General → Your apps → Web app ──────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ─── Google Sign-In ────────────────────────────────────────────────────────────
# Web client ID: Authentication → Sign-in method → Google → Web SDK configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client ID: CLIENT_ID de GoogleService-Info.plist (termina en .apps.googleusercontent.com)
# NO uses REVERSED_CLIENT_ID acá; el URL scheme nativo se deriva solo en app.config.ts
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ─── iOS Personal Team (cuenta Apple gratuita) ───────────────────────────────
# true = instala en iPhone sin Apple Developer pago (sin Push ni Sign in with Apple)
# Después de cambiar esto: pnpm exec expo prebuild --clean && pnpm exec expo run:ios --device
IOS_PERSONAL_TEAM=true
EXPO_PUBLIC_IOS_PERSONAL_TEAM=true

# ─── Push Notifications (EAS) ─────────────────────────────────────────────────
# ID del proyecto en EAS Dashboard (expo.dev → tu proyecto → settings)
EXPO_PUBLIC_EAS_PROJECT_ID=

# ─── API base URL (opcional, para lib/api.ts) ─────────────────────────────────
# EXPO_PUBLIC_API_URL=https://tu-api.com
